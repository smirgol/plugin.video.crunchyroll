# Crunchyroll Test Credentials
# Copy this file to .env and fill in your credentials

# CRITICAL: Get these from your Kodi addon settings
# Settings -> Crunchyroll -> Developer -> Export Credentials
# OR: Check account_data.json in Kodi userdata directory

# Refresh token (longer lived than access token - use this for tests)
CRUNCHYROLL_REFRESH_TOKEN=your_refresh_token_here

# Device ID (bound to your authentication - must match Kodi)
# Format: 8chars-KODI-4chars-4chars-12chars
CRUNCHYROLL_DEVICE_ID=your_device_id_from_kodi

# Optional: Account ID (for verification)
CRUNCHYROLL_ACCOUNT_ID=optional_account_id

# Test Episode ID (for streaming tests - use a stable test episode)
# Default: One Piece episode
TEST_EPISODE_ID=GRVNEX7VY
